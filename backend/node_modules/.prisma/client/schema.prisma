generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANALYST
}

enum DealStatus {
  PENDING
  PROFITABLE
  LOSS
  CLOSED
}

enum Currency {
  GBP
  AED
}

enum CurrencyDisplayFormat {
  SYMBOL
  CODE
}

enum LossHandling {
  CARRY_FORWARD
  WRITE_OFF
  SPLIT_PROPORTIONALLY
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals   Deal[]      @relation("UserDeals")
  reports ReportLog[] @relation("UserReports")
}

model Deal {
  id       String   @id @default(uuid())
  dealId   String   @unique // Backend service will generate DL-0001 format
  dealName String
  date     DateTime
  notes    String?

  itemName         String
  quantity         Int
  costPricePerItem Decimal @db.Decimal(12, 2)
  totalStockCost   Decimal @db.Decimal(12, 2)

  flightCost         Decimal @default(0) @db.Decimal(12, 2)
  luggageCost        Decimal @default(0) @db.Decimal(12, 2)
  transportCost      Decimal @default(0) @db.Decimal(12, 2)
  packageCost        Decimal @default(0) @db.Decimal(12, 2)
  salaryExpense      Decimal @default(0) @db.Decimal(12, 2)
  additionalExpenses Decimal @default(0) @db.Decimal(12, 2)
  miscellaneousNotes String?

  investor1Name         String?
  investor1Contribution Decimal @default(0) @db.Decimal(12, 2)
  investor2Name         String?
  investor2Contribution Decimal @default(0) @db.Decimal(12, 2)
  totalCapitalInvested  Decimal @default(0) @db.Decimal(12, 2)

  totalSaleRevenue Decimal @default(0) @db.Decimal(12, 2)
  totalExpenses    Decimal @default(0) @db.Decimal(12, 2)
  netProfit        Decimal @default(0) @db.Decimal(12, 2)

  profitShareInvestor1 Decimal @default(0) @db.Decimal(5, 2)
  profitShareInvestor2 Decimal @default(0) @db.Decimal(5, 2)

  finalPayoutInvestor1 Decimal @default(0) @db.Decimal(12, 2)
  finalPayoutInvestor2 Decimal @default(0) @db.Decimal(12, 2)

  status   DealStatus @default(PENDING)
  currency Currency   @default(GBP)

  createdById String
  createdBy   User   @relation("UserDeals", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports ReportLog[]
}

model AppSetting {
  id                          String                @id @default(uuid())
  businessName                String
  defaultCurrency             Currency              @default(GBP)
  currencyDisplayFormat       CurrencyDisplayFormat @default(SYMBOL)
  reportFooterText            String?
  businessEmail               String?
  defaultProfitSplitInvestor1 Decimal               @default(50) @db.Decimal(5, 2)
  defaultProfitSplitInvestor2 Decimal               @default(50) @db.Decimal(5, 2)
  lossHandling                LossHandling          @default(SPLIT_PROPORTIONALLY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReportLog {
  id            String   @id @default(uuid())
  dealId        String?
  generatedById String
  reportType    String
  generatedAt   DateTime @default(now())

  deal        Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)
  generatedBy User  @relation("UserReports", fields: [generatedById], references: [id], onDelete: Cascade)
}
